---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section id="about">
    <div class="container">
        <div class="reveal-text" style="text-align: center;">
            <div class="info-badge" style="border-color: var(--text-muted); color: var(--text-main);">{t('about_badge')}</div>
            <h2 class="section-title">{t('about_title')}</h2>
        </div>
        <div class="about-grid">
            <div class="about-text reveal-text delay-100">
                <p>{t('about_text_1')}</p>
                <p>{t('about_text_2')}</p>
                <ul class="about-list">
                    <li><svg class="svg-icon" viewBox="0 0 24 24"><path d="M19 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-9 14l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg> <span>{t('about_li1')}</span></li>
                    <li><svg class="svg-icon" viewBox="0 0 24 24"><path d="M19 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-9 14l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg> <span>{t('about_li2')}</span></li>
                    <li><svg class="svg-icon" viewBox="0 0 24 24"><path d="M19 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-9 14l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg> <span>{t('about_li3')}</span></li>
                    <li><svg class="svg-icon" viewBox="0 0 24 24"><path d="M19 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-9 14l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg> <span>{t('about_li4')}</span></li>
                </ul>
            </div>
            <div class="about-card-wrapper reveal-scale delay-200">
                <div class="strict-card">
                    <svg class="svg-icon card-icon" viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg>
                    <h3>{t('requisites_title')}</h3>
                    <p class="company-name"><strong>"INDUSTRY AND TECHNOLOGY" LLC</strong></p>
                    <p class="company-address">{t('requisites_address')}</p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .about-grid { display: flex; flex-wrap: wrap; gap: clamp(32px, 5vw, 48px); margin-top: clamp(32px, 5vw, 48px); }
    .about-text { flex: 1.5; min-width: 280px; }
    .about-text p { color: var(--text-muted); font-size: 1.1rem; margin-bottom: 24px; }
    
    .about-list { list-style: none; margin-top: 32px; display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    .about-list li { display: flex; align-items: flex-start; gap: 16px; font-size: 1rem; color: #e2e8f0; }
    .about-list svg { color: var(--accent); margin-top: 4px; flex-shrink: 0;}
    
    .about-card-wrapper { flex: 1; min-width: 280px; }
    .strict-card { background: var(--surface); padding: 48px; border: 1px solid var(--border); transition: var(--transition); border-radius: 4px; }
    .strict-card:hover { border-color: var(--border-highlight); background: var(--surface-hover); box-shadow: 0 10px 30px rgba(0,0,0,0.5); transform: translateY(-4px); }
    .card-icon { font-size: 2rem; color: var(--accent); margin-bottom: 24px; }
    .strict-card h3 { margin-bottom: 16px; font-size: 1.2rem; }
    .company-name { color: var(--text-muted); margin-bottom: 16px; }
    .company-address { color: var(--text-muted); font-size: 0.9rem; }

    @media (max-width: 1024px) {
        .about-list { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
        .strict-card { padding: 24px; }
    }
</style>
